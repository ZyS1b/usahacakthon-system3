# AI API Key (OpenAI-compatible)
AI_API_KEY=sk-your-api-key-here

# AI provider base URL
# For OpenAI: leave empty (defaults to https://api.openai.com/v1)
# For DeepSeek: https://api.deepseek.com
# For Azure: https://YOUR_RESOURCE_NAME.openai.azure.com
AI_BASE_URL=https://api.deepseek.com

# AI model name
# For OpenAI: gpt-4o-mini, gpt-4o, etc.
# For DeepSeek: deepseek-chat
AI_MODEL=deepseek-chat

# JWT Secret (for auth - change this in production)
SECRET_KEY=your-secret-key-change-this-in-production